<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="BlackSync.Views.MigracaoView">

	<ScrollViewer VerticalScrollBarVisibility="Auto">
		<Grid Margin="20" ColumnDefinitions="*, *" RowDefinitions="Auto, Auto, Auto, Auto" MaxWidth="850">

			<TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Migração de Tabelas Firebird → MySQL" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

			<StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,15,0">
				<TextBlock Text="Tabelas Firebird" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>

				<ListBox x:Name="lbTabelasFirebird" Focusable="True" SelectionMode="Multiple"
						 Height="330" CornerRadius="4" BorderBrush="#CCC" BorderThickness="1" Margin="0,0,0,10">
					<ListBox.ItemTemplate>
						<DataTemplate>
							<CheckBox Content="{Binding Nome}" IsChecked="{Binding Selecionado, Mode=TwoWay}" />
						</DataTemplate>
					</ListBox.ItemTemplate>
				</ListBox>

				<StackPanel Spacing="5">
					<CheckBox x:Name="cbMarcarTodas" Content="Selecionar todas as tabelas" Checked="CbMarcarTodas_Changed" Unchecked="CbMarcarTodas_Changed"/>
					<CheckBox x:Name="cbCadastro" Content="Selecionar cadastro" Checked="CbCadastro_Changed" Unchecked="CbCadastro_Changed"/>
					<CheckBox x:Name="cbMovimento" Content="Selecionar movimento" Checked="CbMovimento_Changed" Unchecked="CbMovimento_Changed"/>
					<CheckBox x:Name="cbCadastroMovimento" Content="Selecionar cadastro e movimento" Checked="CbCadastroMovimento_Changed" Unchecked="CbCadastroMovimento_Changed"/>
				</StackPanel>
			</StackPanel>

			<StackPanel Grid.Row="1" Grid.Column="1" Margin="15,0,0,0" Spacing="15">

				<TextBlock Text="Ações de Migração" FontSize="16" FontWeight="Bold"/>

				<WrapPanel>
					<Button x:Name="btnVerificarTabelas" Content="Verificar tabelas" Width="140" Margin="0,0,10,10" Background="#9C27B0" Foreground="White" FontWeight="Bold" HorizontalContentAlignment="Center" CornerRadius="4"/>
					<Button x:Name="btnVerificarEstrutura" Content="Verificar estrutura" Width="140" Margin="0,0,10,10" Background="#9C27B0" Foreground="White" FontWeight="Bold" HorizontalContentAlignment="Center" CornerRadius="4"/>
					<Button x:Name="btnMigrar" Content="Migrar tabelas" Width="140" Margin="0,0,10,10" Background="#8a0194" Foreground="White" FontWeight="Bold" HorizontalContentAlignment="Center" CornerRadius="4"/>
				</WrapPanel>

				<Separator Background="#E0E0E0" Margin="5"/>

				<TextBlock Text="📦 Migrar ZPL (Access)" FontSize="16" FontWeight="Bold"/>

				<Grid ColumnDefinitions="*, Auto" Margin="0,0,0,10">
					<TextBox x:Name="txtCaminhoArquivoAccess" Grid.Column="0" Watermark="Caminho do arquivo .mdb" CornerRadius="4,0,0,4"/>
					<Button x:Name="btnSelecionar" Grid.Column="1" Width="40" Background="#9C27B0" CornerRadius="0,4,4,0" ToolTip.Tip="Selecionar">
						<Image Source="avares://BlackSync/Assets/Icons/search.png" Width="18" Height="18"/>
					</Button>
				</Grid>

				<WrapPanel>
					<Button x:Name="btnLimpar" Content="Limpar ZPL" Width="140" Margin="0,0,10,10" Background="#9C27B0" Foreground="White" FontWeight="Bold" HorizontalContentAlignment="Center" CornerRadius="4"/>
					<Button x:Name="btnImportarZPL" Content="Importar ZPL" Width="140" Margin="0,0,10,10" Background="#9C27B0" Foreground="White" FontWeight="Bold" HorizontalContentAlignment="Center" CornerRadius="4"/>
				</WrapPanel>

				<Separator Background="#E0E0E0" Margin="5"/>

				<TextBlock Text="Utilitários" FontSize="16" FontWeight="Bold"/>
				<WrapPanel>
					<Button x:Name="btnGerarScripts" Content="Gerar Scripts SQL" Width="140" Margin="0,0,10,10" Background="#9C27B0" Foreground="White" FontWeight="Bold" HorizontalContentAlignment="Center" CornerRadius="4"/>
					<Button x:Name="btnGerarFeedback" Content="Gerar Feedback" Width="140" Margin="0,0,10,10" Background="#9C27B0" Foreground="White" FontWeight="Bold" HorizontalContentAlignment="Center" CornerRadius="4"/>
				</WrapPanel>

			</StackPanel>

			<ProgressBar x:Name="pbMigracao" Grid.Row="2" Grid.ColumnSpan="2" Height="10" Minimum="0" Maximum="100" Value="0" IsVisible="False" Foreground="#8a0194" Margin="0,20,0,5" CornerRadius="4"/>

			<StackPanel Grid.Row="3" Grid.ColumnSpan="2" Margin="0,10,0,0">
				<TextBlock Text="Log de verificação" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
				<TextBox x:Name="txtLog" AcceptsReturn="True" IsReadOnly="True" Height="120" Foreground="#000" CornerRadius="4" ScrollViewer.VerticalScrollBarVisibility="Auto"/>
			</StackPanel>

		</Grid>
	</ScrollViewer>
</UserControl>