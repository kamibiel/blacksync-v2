<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="BlackSync.Views.ConfiguracaoView">

	<Grid Margin="20">
		<ScrollViewer VerticalScrollBarVisibility="Auto">
			<StackPanel Margin="10" Spacing="30" HorizontalAlignment="Center" MaxWidth="600">

				<TextBlock Text="Configuração"
						   FontSize="24"
						   FontWeight="Bold"
						   HorizontalAlignment="Center"/>

				<StackPanel Spacing="10">
					<TextBlock Text="Conexão do Firebird" FontSize="16" FontWeight="Bold"/>
					<TextBox x:Name="txtDSN" HorizontalAlignment="Stretch" Padding="10" Watermark="DSN" Foreground="#000"/>
				</StackPanel>

				<StackPanel Spacing="10">
					<TextBlock Text="Conexão do MySQL" FontSize="16" FontWeight="Bold"/>

					<Grid RowDefinitions="Auto, Auto, Auto" ColumnDefinitions="*, *" Margin="0,5,0,0">

						<TextBox x:Name="txtServidor" Grid.Row="0" Grid.Column="0" Margin="0,0,10,15" Padding="10" Watermark="Servidor" Foreground="#000"/>
						<TextBox x:Name="txtPorta" Grid.Row="0" Grid.Column="1" Margin="10,0,0,15" Padding="10" Watermark="Porta" Foreground="#000"/>

						<TextBox x:Name="txtUsuario" Grid.Row="1" Grid.Column="0" Margin="0,0,10,15" Padding="10" Watermark="Usuário" Foreground="#000"/>
						<TextBox x:Name="txtSenha" Grid.Row="1" Grid.Column="1" Margin="10,0,0,15" Padding="10" Watermark="Senha" AcceptsReturn="False" PasswordChar="*" Foreground="#000"/>

						<TextBox x:Name="txtBanco" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Padding="10" Watermark="Banco de Dados" Foreground="#000"/>

					</Grid>
				</StackPanel>

				<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="15" Margin="0,10,0,0">
					<Button Click="BtnLimpar_Click" Content="Limpar" Width="140" Background="#9C27B0" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" CornerRadius="4"/>
					<Button Click="BtnTestarConexao_Click" Content="Teste conexão" Width="140" Background="#9C27B0" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" CornerRadius="4"/>
					<Button Click="BtnSalvar_Click" Content="Salvar" Width="140" Background="#8a0194" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" CornerRadius="4"/>
				</StackPanel>

			</StackPanel>
		</ScrollViewer>
	</Grid>
</UserControl>